# =============================================================================
# InvestSnap — konfiguracja srodowiskowa
# =============================================================================
# Skopiuj ten plik jako .env i uzupelnij wartosci.
# Plik .env NIE jest commitowany do repozytorium (jest w .gitignore).
#
#   cp .env.example .env
#
# Zmienne z wartoscia domyslna sa opcjonalne — wystarczy odkomentowac
# i zmienic, jesli chcesz nadpisac domyslna wartosc.
# =============================================================================

# ---------------------------------------------------------------------------
# SEC EDGAR  (wymagane: email kontaktowy w User-Agent)
# ---------------------------------------------------------------------------
# SEC wymaga podania adresu email w naglowku User-Agent.
# Bez tego mozesz dostac HTTP 403.
SEC_USER_AGENT=InvestSnap/1.0 (twoj-email@example.com)

# ---------------------------------------------------------------------------
# OpenFIGI  (opcjonalny klucz API)
# ---------------------------------------------------------------------------
# Bez klucza: 10 CUSIPow/batch, 25 req/min
# Z kluczem:  100 CUSIPow/batch, 250 req/min
# Zarejestruj sie na: https://www.openfigi.com/api#api-key
# OPENFIGI_API_KEY=

# ---------------------------------------------------------------------------
# Sciezki (opcjonalne — domyslne wartosci dzialaja z repo)
# ---------------------------------------------------------------------------
# DATA_DIR=dane
# REPORTS_DIR=raporty

# ---------------------------------------------------------------------------
# Fundusze 13F (domyslnie sledzone — mozna wylaczyc)
# ---------------------------------------------------------------------------
# Ustaw na "false" zeby pominac sekcje funduszy w raporcie.
# ENABLE_FUND_TRACKING=true
